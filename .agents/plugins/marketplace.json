      },
      "category": "Productivity"
    },
    {
      "name": "playwright-cli",
      "source": {
        "source": "local",
        "path": "./plugins/playwright-cli"
      },
      "policy": {
        "installation": "AVAILABLE",
        "authentication": "ON_INSTALL"
      },
      "category": "Developer Tools"
    },
    {
      "name": "remora",
      "source": {
        "source": "local",
        "path": "./plugins/remora"
      },
      "policy": {
        "installation": "AVAILABLE",
        "authentication": "ON_INSTALL"
      },
      "category": "Developer Tools"
