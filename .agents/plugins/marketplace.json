        "source": "local",
        "path": "./plugins/exam-generator"
      },
      "policy": {
        "installation": "AVAILABLE",
        "authentication": "ON_INSTALL"
      },
      "category": "Productivity"
    },
    {
      "name": "playwright-cli",
      "source": {
        "source": "local",
        "path": "./plugins/playwright-cli"
      },
      "policy": {
        "installation": "AVAILABLE",
        "authentication": "ON_INSTALL"
      },
      "category": "Developer Tools"
    },
    {
      "name": "mimo",
      "description": "MiMo programming assistant — code review, task delegation, and stop-gate review",
      "source": {
        "source": "local",
        "path": "./plugins/mimo"
      },
      "policy": {
        "installation": "AVAILABLE",
        "authentication": "ON_INSTALL"
      },
