{
  "name": "huayi-dev-plugins",
  "interface": {
    "displayName": "Huayi Dev Plugins"
  },
  "plugins": [
    {
      "name": "gitlab-dev",
      "description": "GitLab 开发助手 — mr、review、resolve、conflict 四个专项 skill，结合 glab CLI 管理项目交付",
      "source": {
        "source": "local",
        "path": "./plugins/gitlab-dev"
      },
      "policy": {
        "installation": "AVAILABLE",
        "authentication": "ON_INSTALL"
      },
      "category": "Developer Tools"
    },
    {
      "name": "exam-generator",
      "source": {
        "source": "local",
        "path": "./plugins/exam-generator"
      },
      "policy": {
        "installation": "AVAILABLE",
        "authentication": "ON_INSTALL"
      },
      "category": "Productivity"
    },
    {
      "name": "playwright-cli",
      "source": {
        "source": "local",
        "path": "./plugins/playwright-cli"
      },
      "policy": {
        "installation": "AVAILABLE",
        "authentication": "ON_INSTALL"
      },
      "category": "Developer Tools"
    }
  ]
}
