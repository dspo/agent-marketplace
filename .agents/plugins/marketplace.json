{
  "name": "remora-plugins",
  "interface": {
    "displayName": "Remora Plugins"
  },
  "plugins": [
    {
      "name": "gitwork",
      "description": "Git platform development assistant — deliver, review, resolve, and conflict skills combined with gh / glab CLI for GitHub and GitLab project delivery",
      "source": {
        "source": "local",
        "path": "./plugins/gitwork"
      },
      "policy": {
        "installation": "AVAILABLE",
        "authentication": "ON_INSTALL"
      },
      "category": "Developer Tools"
    },
    {
      "name": "exam-generator",
